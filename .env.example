# EmailJS configuration (frontend-safe)
# Obtain these from EmailJS dashboard and paste into your local .env file
# For Vite, variables must be prefixed with VITE_

VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id

# The EmailJS template must use {{to_email}} or {{recipient_email}} as the recipient.
# Grando configurator quote requests pass info@eudaemonia.tech in both fields.

# Preferred quote/contact delivery path. This keeps mail credentials server-side.
VITE_EMAIL_API_ENDPOINT=/.netlify/functions/send-email

# Optional marketing/search exposure configuration. Leave blank until each platform is ready.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=
VITE_GTM_ID=
VITE_GA_MEASUREMENT_ID=
VITE_GOOGLE_ADS_ID=
VITE_GOOGLE_ADS_QUOTE_CONVERSION_LABEL=
VITE_LINKEDIN_PARTNER_ID=
VITE_LINKEDIN_QUOTE_CONVERSION_ID=
VITE_MARKETING_EVENT_ENDPOINT=/.netlify/functions/marketing-event

# Server-only Netlify Function environment variables. Do not prefix these with VITE_.
QUOTE_RECIPIENT_EMAIL=info@eudaemonia.tech
QUOTE_SENDER_EMAIL=frank.hsu@eudaemonia.tech
QUOTE_INBOX_COPY_EMAIL=frank.hsu@eudaemonia.tech
GMAIL_OAUTH_CLIENT_ID=your_google_oauth_client_id
GMAIL_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
