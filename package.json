{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rm -rf node_modules/.vite && vite --force",
    "dev:full": "bash prepare-deploy.sh && vite --force",
    "dev:clean": "rm -rf node_modules/.vite dist && vite --force",
    "build": "npm run generate:social-images && node scripts/generate-discovery-files.cjs && node scripts/verify-discovery.cjs && npm run clean:public-assets:safe-duplicates && bash prepare-deploy.sh && vite build && node scripts/generate-build-metadata.cjs && node scripts/generate-static-seo-pages.cjs && node scripts/verify-static-seo.cjs",
    "build:vercel": "npm run generate:social-images && node scripts/generate-discovery-files.cjs && node scripts/verify-discovery.cjs && npm run clean:public-assets:safe-duplicates && bash prepare-deploy.sh && vite build && node scripts/generate-build-metadata.cjs && node scripts/generate-static-seo-pages.cjs && node scripts/verify-static-seo.cjs && node scripts/vercel-build.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "postbuild": "node scripts/inject-version.cjs",
    "test-env": "vite preview --open public/test-environment.html",
    "build:netlify": "npm run generate:social-images && node scripts/generate-discovery-files.cjs && node scripts/verify-discovery.cjs && npm run clean:public-assets:safe-duplicates && vite build && node scripts/generate-build-metadata.cjs && node scripts/generate-static-seo-pages.cjs && node scripts/verify-static-seo.cjs",
    "submit:indexnow": "npm run generate:social-images && node scripts/generate-discovery-files.cjs && node scripts/verify-discovery.cjs && node scripts/submit-indexnow.cjs",
    "submit:indexnow:current": "node scripts/submit-indexnow.cjs",
    "submit:indexnow:dry-run": "node scripts/submit-indexnow.cjs --dry-run",
    "submit:search-console": "npm run generate:social-images && node scripts/generate-discovery-files.cjs && node scripts/verify-discovery.cjs && node scripts/submit-google-search-console.cjs",
    "generate:social-images": "node scripts/generate-configurator-social-images.cjs",
    "verify:social-images": "node scripts/generate-configurator-social-images.cjs --check",
    "generate:promotion-assets": "node scripts/generate-configurator-promotion-assets.cjs",
    "verify:promotion-assets": "node scripts/generate-configurator-promotion-assets.cjs --check",
    "verify:marketing-platform-env": "node scripts/verify-marketing-platform-env.cjs --write-report",
    "verify:marketing-platform-env:readonly": "node scripts/verify-marketing-platform-env.cjs",
    "verify:marketing-platform-env:strict:readonly": "node scripts/verify-marketing-platform-env.cjs --fail-on-missing",
    "verify:marketing-platform-env:strict": "node scripts/verify-marketing-platform-env.cjs --write-report --fail-on-missing",
    "create:marketing-env-template": "node scripts/create-marketing-env-template.cjs --output marketing.env",
    "sync:marketing-platform-env": "node scripts/sync-marketing-platform-env.cjs",
    "create:marketing-1password-template": "node scripts/create-marketing-1password-template.cjs --output marketing-1password-item.json",
    "verify:marketing-1password-item": "node scripts/verify-marketing-1password-item.cjs --write-report",
    "verify:marketing-1password-item:structure:strict": "node scripts/verify-marketing-1password-item.cjs --structure-only --fail-on-missing",
    "verify:marketing-1password-item:strict": "node scripts/verify-marketing-1password-item.cjs --write-report --fail-on-missing",
    "verify:exposure-workflow-env": "node scripts/verify-exposure-workflow-env.cjs",
    "verify:scheduled-exposure": "node scripts/verify-scheduled-exposure-function.cjs",
    "apply:marketing-platform-env:netlify": "node scripts/apply-marketing-platform-env-to-netlify.cjs",
    "audit:external-platform-access": "node scripts/audit-external-platform-access.cjs --write-report",
    "audit:external-platform-access:readonly": "node scripts/audit-external-platform-access.cjs",
    "audit:external-platform-access:strict": "node scripts/audit-external-platform-access.cjs --write-report --fail-on-missing",
    "audit:external-exposure-status": "node scripts/audit-external-exposure-status.cjs --write-report",
    "audit:external-exposure-status:readonly": "node scripts/audit-external-exposure-status.cjs",
    "audit:external-exposure-status:strict": "node scripts/audit-external-exposure-status.cjs --write-report --fail-on-missing",
    "audit:configurator-route-coverage": "node scripts/audit-configurator-route-coverage.cjs --write-report",
    "audit:configurator-route-coverage:readonly": "node scripts/audit-configurator-route-coverage.cjs",
    "audit:configurator-route-coverage:strict": "node scripts/audit-configurator-route-coverage.cjs --write-report --fail-on-drift",
    "audit:public-assets": "node scripts/audit-public-assets.cjs",
    "audit:public-assets:safe-duplicates": "node scripts/audit-public-assets.cjs --fail-on-safe-duplicates --summary-only",
    "clean:public-assets:safe-duplicates": "node scripts/audit-public-assets.cjs --write-report --delete-safe-duplicates --summary-only",
    "audit:public-assets:strict": "node scripts/audit-public-assets.cjs --write-report --fail-on-issues",
    "audit:exposure-readiness": "node scripts/audit-configurator-exposure-readiness.cjs --write-report",
    "audit:exposure-summary": "node scripts/audit-configurator-exposure-readiness.cjs --write-report --write-summary --summary-only",
    "audit:exposure-readiness:strict": "node scripts/audit-configurator-exposure-readiness.cjs --write-report --fail-on-external-gaps",
    "audit:exposure-readiness:production": "node scripts/audit-configurator-exposure-readiness.cjs --write-report --fail-on-production-probes",
    "inspect:search-console": "node scripts/inspect-google-search-console.cjs",
    "report:search-console": "node scripts/report-google-search-console.cjs",
    "verify:live-exposure": "node scripts/verify-live-exposure.cjs",
    "verify:marketing-event-health": "node scripts/check-marketing-event-health.cjs",
    "monitor:sitemaps": "node scripts/monitor-google-search-console-sitemaps.cjs",
    "exposure:public:readonly": "npm run verify:discovery && npm run verify:seo-html && npm run verify:social-images && npm run verify:promotion-assets && npm run verify:scheduled-exposure && npm run audit:configurator-route-coverage:strict && npm run audit:public-assets && npm run audit:public-assets:safe-duplicates && npm run verify:live-exposure && npm run submit:indexnow:dry-run && npm run verify:marketing-event-health",
    "exposure:postdeploy": "npm run verify:live-exposure && npm run submit:search-console && npm run monitor:sitemaps && npm run inspect:search-console -- --include-aliases && npm run report:search-console -- --days=90 --row-limit=50 --output=reports/search-console-latest.json",
    "exposure:strict": "npm run verify:live-exposure && npm run submit:search-console && npm run monitor:sitemaps && npm run inspect:search-console -- --include-aliases --fail-on-unindexed --fail-on-canonical-mismatch && npm run report:search-console -- --days=90 --row-limit=50 --output=reports/search-console-latest.json --fail-on-empty",
    "verify:discovery": "node scripts/verify-discovery.cjs",
    "verify:seo-html": "node scripts/verify-static-seo.cjs"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "axios": "^1.10.0",
    "google-auth-library": "^10.1.0",
    "lucide-react": "^0.344.0",
    "nodemailer": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.22.3",
    "web-vitals": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
