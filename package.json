{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rm -rf node_modules/.vite && vite --force",
    "dev:full": "bash prepare-deploy.sh && vite --force",
    "dev:clean": "rm -rf node_modules/.vite dist && vite --force",
    "build": "bash prepare-deploy.sh && vite build",
    "build:vercel": "bash prepare-deploy.sh && vite build && node scripts/vercel-build.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "postbuild": "node scripts/inject-version.cjs",
    "test-env": "vite preview --open public/test-environment.html"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "axios": "^1.10.0",
    "google-auth-library": "^10.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.22.3",
    "web-vitals": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
